# ════════════════════════════════════════════════════════════
# Provider por defecto
# ════════════════════════════════════════════════════════════

# API key del proveedor destino
# OpenAI:      sk-tu-key
# NVIDIA:      nvapi-tu-key
# Gemini:      AIzaSy...
# Ollama:      ollama
# DeepSeek:    sk-tu-key
# Groq:        gsk_tu-key
# OpenRouter:  sk-or-v1-tu-key
# Anthropic:   sk-ant-... (autodetecta passthrough)
TARGET_API_KEY=sk-tu-api-key-aqui

# Modelo a usar en el proveedor destino
# OpenAI:      gpt-4o
# NVIDIA:      meta/llama-3.1-8b-instruct
# Gemini:      gemini-2.5-flash
# Ollama:      llama3.1
# DeepSeek:    deepseek-chat
# Groq:        llama-3.3-70b-versatile
# OpenRouter:  google/gemini-2.5-pro
TARGET_MODEL=gpt-4o

# URL base del proveedor destino
# OpenAI:      https://api.openai.com
# NVIDIA:      https://integrate.api.nvidia.com
# Gemini:      https://generativelanguage.googleapis.com/v1beta/openai
# Ollama:      http://localhost:11434
# DeepSeek:    https://api.deepseek.com
# Groq:        https://api.groq.com/openai
# OpenRouter:  https://openrouter.ai/api
# Anthropic:   https://api.anthropic.com (passthrough automático)
TARGET_BASE_URL=https://api.openai.com

# Forzar passthrough (sin traducción) — útil cuando el endpoint
# habla nativo Anthropic Messages API. Auto-detectado por host.
# TARGET_PASSTHROUGH=false

# ════════════════════════════════════════════════════════════
# Routing avanzado (opcional)
# ════════════════════════════════════════════════════════════

# Alias simple de modelos (mismo provider que TARGET_*):
#   { "claude-modelo-anthropic": "modelo-destino" }
# MODEL_MAP_JSON={"claude-opus-4-20250514":"gpt-4-turbo"}

# Routing completo por modelo a providers distintos.
# Cada entry: { name?, baseUrl, apiKey, model, passthrough? }
# PROVIDERS_JSON={"claude-opus-4-20250514":{"name":"nvidia","baseUrl":"https://integrate.api.nvidia.com","apiKey":"nvapi-xxx","model":"meta/llama-3.1-70b-instruct"}}

# ════════════════════════════════════════════════════════════
# Servidor
# ════════════════════════════════════════════════════════════

PROXY_PORT=8082

# Logging
# LOG_LEVEL=info        # debug | info | warn | error
# LOG_FORMAT=pretty     # pretty | json
# LOG_REDACT=true       # redactar API keys en logs
# LOG_REQUESTS=true     # legacy, equivalente a LOG_LEVEL=debug

# ════════════════════════════════════════════════════════════
# Conexión
# ════════════════════════════════════════════════════════════
# MAX_SOCKETS=10
# KEEP_ALIVE=true
# ALLOW_H2=false
# CONNECTION_TIMEOUT=30000
# REQUEST_TIMEOUT=120000

# ════════════════════════════════════════════════════════════
# Retry
# ════════════════════════════════════════════════════════════
# MAX_RETRIES=3
# RETRY_DELAY_MS=1000
# RETRY_BACKOFF_MULTIPLIER=2
# RETRY_MAX_DELAY_MS=30000

# ════════════════════════════════════════════════════════════
# Rate limiting (0 = deshabilitado)
# ════════════════════════════════════════════════════════════
# RATE_LIMIT_MAX=60
# RATE_LIMIT_WINDOW_MS=60000

# ════════════════════════════════════════════════════════════
# CORS
# ════════════════════════════════════════════════════════════
# CORS_ORIGINS=*    # o "https://app.example.com,https://other.com"
# CORS_ALLOWED_HEADERS=Content-Type, Authorization, x-api-key, anthropic-version

# ════════════════════════════════════════════════════════════
# Cache de respuestas (no-streaming)
# ════════════════════════════════════════════════════════════
# CACHE_ENABLED=false
# CACHE_TTL_MS=60000
# CACHE_MAX_SIZE=100

# ════════════════════════════════════════════════════════════
# Limits y shutdown
# ════════════════════════════════════════════════════════════
# MAX_BODY_SIZE=10485760     # 10 MB
# SHUTDOWN_TIMEOUT_MS=30000
